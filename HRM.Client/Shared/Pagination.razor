<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 px-4 py-3 bg-white border-t border-gray-200 rounded-b-lg">
    <div class="flex items-center gap-2 text-sm text-gray-500">
        <span class="hidden sm:inline">Rows per page:</span>
        <select value="@PageSize" @onchange="OnPageSizeChange" class="border border-gray-300 rounded px-2 py-1 text-sm">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="25">25</option>
        </select>
        <span>@(((Page - 1) * PageSize) + 1)–@(Math.Min(Page * PageSize, TotalCount)) of @TotalCount</span>
    </div>
    <div class="flex items-center gap-1 text-sm">
        <button disabled="@(Page <= 1)" @onclick="() => GoToPage(1)" class="p-1 rounded hover:bg-gray-100 disabled:opacity-30">
            <span class="material-icons-outlined text-sm">first_page</span>
        </button>
        <button disabled="@(Page <= 1)" @onclick="() => GoToPage(Page - 1)" class="p-1 rounded hover:bg-gray-100 disabled:opacity-30">
            <span class="material-icons-outlined text-sm">chevron_left</span>
        </button>
        <span class="text-gray-500 mx-1 text-xs">@Page / @TotalPages</span>
        <button disabled="@(Page >= TotalPages)" @onclick="() => GoToPage(Page + 1)" class="p-1 rounded hover:bg-gray-100 disabled:opacity-30">
            <span class="material-icons-outlined text-sm">chevron_right</span>
        </button>
        <button disabled="@(Page >= TotalPages)" @onclick="() => GoToPage(TotalPages)" class="p-1 rounded hover:bg-gray-100 disabled:opacity-30">
            <span class="material-icons-outlined text-sm">last_page</span>
        </button>
    </div>
</div>

@code {
    [Parameter] public int Page { get; set; } = 1;
    [Parameter] public int PageSize { get; set; } = 5;
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public EventCallback<int> PageChanged { get; set; }
    [Parameter] public EventCallback<int> PageSizeChanged { get; set; }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(TotalCount / (double)PageSize));

    private async Task GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
            await PageChanged.InvokeAsync(page);
    }

    private async Task OnPageSizeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
            await PageSizeChanged.InvokeAsync(size);
    }
}
