<div class="mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
            <h1 class="text-xl sm:text-2xl font-semibold text-gray-800">@Title</h1>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <p class="text-sm text-gray-500 mt-1">@Subtitle</p>
            }
        </div>
        @if (Breadcrumb is not null)
        {
            <nav class="text-sm text-gray-500 flex items-center gap-1 flex-shrink-0">
                <a href="" class="hover:text-gray-700"><span class="material-icons-outlined text-sm">home</span></a>
                @Breadcrumb
            </nav>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? Breadcrumb { get; set; }
}
