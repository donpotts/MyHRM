<div class="border-b border-gray-200 bg-white rounded-t-lg overflow-x-auto">
    <nav class="flex gap-0 px-2 min-w-max">
        @foreach (var tab in Tabs)
        {
            var isActive = tab.Key == ActiveTab;
            <button @onclick="() => OnTabChanged.InvokeAsync(tab.Key)"
                    class="flex items-center gap-1.5 px-3 py-3 text-sm font-medium border-b-2 transition-colors whitespace-nowrap @(isActive ? "border-indigo-600 text-indigo-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300")">
                @if (!string.IsNullOrEmpty(tab.Value))
                {
                    <span class="material-icons-outlined text-base">@tab.Value</span>
                }
                @tab.Key
            </button>
        }
    </nav>
</div>

@code {
    [Parameter] public Dictionary<string, string> Tabs { get; set; } = new();
    [Parameter] public string ActiveTab { get; set; } = "";
    [Parameter] public EventCallback<string> OnTabChanged { get; set; }
}
