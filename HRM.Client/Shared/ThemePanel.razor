@inject ThemeService Theme
@implements IDisposable

@if (Open)
{
    <div class="fixed inset-0 z-40" @onclick="Close"></div>
    <div class="absolute right-0 top-12 z-50 bg-white rounded-xl shadow-xl border border-gray-100 p-4 w-56">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Appearance</p>

        @* Light / Dark toggle *@
        <div class="flex items-center justify-between mb-4">
            <span class="text-sm text-gray-700 flex items-center gap-1.5">
                <span class="material-icons-outlined text-base">@(Theme.IsDark ? "dark_mode" : "light_mode")</span>
                @(Theme.IsDark ? "Dark" : "Light") Mode
            </span>
            <button @onclick="ToggleTheme"
                    class="@(Theme.IsDark ? "bg-indigo-600" : "bg-gray-200") relative inline-flex h-6 w-11 items-center rounded-full transition-colors">
                <span class="@(Theme.IsDark ? "translate-x-6" : "translate-x-1") inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow-sm"></span>
            </button>
        </div>

        <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-2">Accent Color</p>
        <div class="flex flex-wrap gap-2">
            @foreach (var a in Accents)
            {
                <button @onclick="() => SetAccent(a.Key)"
                        title="@a.Key"
                        class="w-7 h-7 rounded-full transition-all @(Theme.Accent == a.Key ? "ring-2 ring-offset-2 ring-gray-400 scale-110" : "hover:scale-105")"
                        style="background-color: @a.Value">
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    private static readonly Dictionary<string, string> Accents = new()
    {
        { "indigo",  "#6366f1" },
        { "violet",  "#7c3aed" },
        { "blue",    "#2563eb" },
        { "emerald", "#059669" },
        { "rose",    "#e11d48" },
        { "amber",   "#d97706" },
    };

    protected override void OnInitialized() => Theme.OnChange += StateHasChanged;
    public void Dispose()                   => Theme.OnChange -= StateHasChanged;

    private async Task Close()        => await OpenChanged.InvokeAsync(false);
    private async Task ToggleTheme()  => await Theme.ToggleThemeAsync();
    private async Task SetAccent(string accent) => await Theme.SetAccentAsync(accent);
}
