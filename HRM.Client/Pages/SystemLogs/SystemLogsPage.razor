@page "/system-logs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiService Api

<PageTitle>System Logs</PageTitle>

<TabContainer Tabs="tabs" ActiveTab="@activeTab" OnTabChanged="t => activeTab = t" />

<div class="bg-white rounded-b-lg border border-t-0 border-gray-200 p-4">
    @switch (activeTab)
    {
        case "Database Log":
            <PageHeader Title="Database Logs" Subtitle="Application logs stored in the database." />
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <input @bind="search" @bind:event="oninput" placeholder="Search logs..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full sm:w-64" />
                <button @onclick="Load" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium">Search</button>
                <button @onclick="Load" class="px-3 py-2 border border-gray-300 rounded-lg text-sm flex items-center gap-1 hover:bg-gray-50">
                    <span class="material-icons-outlined text-sm">refresh</span>
                    <span class="hidden sm:inline">Refresh</span>
                </button>
            </div>
            @if (logs?.Items is not null)
            {
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[500px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Timestamp</th>
                                <th class="px-4 py-3">Level</th>
                                <th class="px-4 py-3">Message</th>
                                <th class="px-4 py-3">Source</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in logs.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded text-xs font-medium @LogLevelColor(log.Level)">@log.Level</span>
                                    </td>
                                    <td class="px-4 py-3 text-sm max-w-xs truncate">@log.Message</td>
                                    <td class="px-4 py-3 text-xs text-gray-400">@log.Source</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <Pagination Page="page" PageSize="pageSize" TotalCount="logs.TotalCount"
                            PageChanged="p => { page = p; _ = Load(); }" PageSizeChanged="s => { pageSize = s; page = 1; _ = Load(); }" />
            }
            else
            {
                <p class="text-gray-400 text-sm text-center py-8">No log entries found.</p>
            }
            break;

        case "File Log":
            <PageHeader Title="File Logs" Subtitle="Application logs written to the file system." />
            <div class="bg-gray-900 text-green-400 rounded-lg p-3 sm:p-4 font-mono text-xs max-h-96 overflow-y-auto">
                <p>Log files are stored at: Logs/hrm-*.log</p>
                <p class="text-gray-500 mt-2">File log viewer is read-only. Check the server filesystem for log files.</p>
            </div>
            break;
    }
</div>

@code {
    private string activeTab = "Database Log";
    private Dictionary<string, string> tabs = new()
    {
        ["Database Log"] = "storage",
        ["File Log"] = "description"
    };

    private PagedResult<SystemLog>? logs;
    private string search = "";
    private int page = 1, pageSize = 10;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<SystemLog>>>($"/api/system-logs?page={page}&pageSize={pageSize}&search={search}");
        logs = r?.Data;
    }

    private string LogLevelColor(string level) => level switch
    {
        "Information" => "bg-blue-100 text-blue-700",
        "Warning" => "bg-yellow-100 text-yellow-700",
        "Error" => "bg-red-100 text-red-700",
        "Critical" => "bg-red-200 text-red-800",
        _ => "bg-gray-100 text-gray-600"
    };
}
