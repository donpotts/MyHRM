@page "/account/login"
@layout HRM.Client.Layout.EmptyLayout
@inject AuthService Auth
@inject BrandingService Branding
@inject NavigationManager Nav

<div class="min-h-screen login-bg login-dot-pattern flex items-center justify-center p-6">
    <div class="w-full max-w-4xl flex flex-col items-center gap-8">

        @* ── Brand ── *@
        <div class="text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-violet-600 mb-5 shadow-lg shadow-indigo-500/30 overflow-hidden">
                @if (!string.IsNullOrWhiteSpace(Branding.LogoUrl))
                {
                    <img src="@Branding.LogoUrl" class="w-10 h-10 object-contain" alt="logo"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
                    <span class="material-icons-outlined text-white text-3xl" style="display:none">corporate_fare</span>
                }
                else
                {
                    <span class="material-icons-outlined text-white text-3xl">corporate_fare</span>
                }
            </div>
            <h1 class="text-3xl font-bold text-white tracking-tight">@Branding.CompanyName</h1>
            <p class="text-indigo-300/70 text-sm mt-1.5 font-medium tracking-wide uppercase text-xs">@Branding.AppTitle</p>
        </div>

        @* ── Main card ── *@
        <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl p-8">

            @if (!showRegister)
            {
                <div class="text-center mb-7">
                    <h2 class="text-xl font-bold text-gray-900">Welcome back</h2>
                    <p class="text-gray-500 text-sm mt-1">Sign in to your account to continue</p>
                </div>

                <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="login">
                    <DataAnnotationsValidator />

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Email Address</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-2.5 text-gray-400 text-[18px]">email</span>
                            <InputText @bind-Value="loginModel.Email"
                                       class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                       placeholder="you@company.com" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Password</label>
                        <div class="relative">
                            <span class="material-icons-outlined absolute left-3 top-2.5 text-gray-400 text-[18px]">lock</span>
                            <InputText @bind-Value="loginModel.Password" type="password"
                                       class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                       placeholder="••••••••" />
                        </div>
                    </div>

                    <div class="flex items-center justify-between mb-6">
                        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
                            <InputCheckbox @bind-Value="loginModel.RememberMe" class="rounded border-gray-300 text-indigo-600" />
                            Remember me
                        </label>
                        <a href="#" class="text-sm text-indigo-600 hover:text-indigo-700 font-medium">Forgot password?</a>
                    </div>

                    <button type="submit" disabled="@loading"
                            class="w-full py-2.5 bg-indigo-600 text-white rounded-xl font-semibold hover:bg-indigo-700 active:bg-indigo-800 transition disabled:opacity-50 flex items-center justify-center gap-2">
                        @if (loading)
                        {
                            <span class="material-icons-outlined text-sm animate-spin">autorenew</span>
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </button>
                </EditForm>

                <div class="flex items-center my-5">
                    <div class="flex-1 border-t border-gray-100"></div>
                    <span class="px-3 text-xs text-gray-400 font-medium">OR</span>
                    <div class="flex-1 border-t border-gray-100"></div>
                </div>

                <button class="w-full py-2.5 border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 flex items-center justify-center gap-2 transition">
                    <svg class="w-4 h-4" viewBox="0 0 24 24">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Continue with Google
                </button>

                <p class="text-center text-sm text-gray-500 mt-5">
                    Don't have an account?
                    <button @onclick="() => showRegister = true" class="text-indigo-600 hover:text-indigo-700 font-semibold">Create Account</button>
                </p>
            }
            else
            {
                <div class="text-center mb-7">
                    <h2 class="text-xl font-bold text-gray-900">Create Account</h2>
                    <p class="text-gray-500 text-sm mt-1">Register to get started</p>
                </div>

                <EditForm Model="registerModel" OnValidSubmit="HandleRegister" FormName="register">
                    <DataAnnotationsValidator />

                    <div class="grid grid-cols-2 gap-3 mb-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">First Name</label>
                            <InputText @bind-Value="registerModel.FirstName"
                                       class="w-full px-3 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                       placeholder="John" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Last Name</label>
                            <InputText @bind-Value="registerModel.LastName"
                                       class="w-full px-3 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                       placeholder="Doe" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Email Address</label>
                        <InputText @bind-Value="registerModel.Email"
                                   class="w-full px-3 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                   placeholder="you@company.com" />
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Password</label>
                        <InputText @bind-Value="registerModel.Password" type="password"
                                   class="w-full px-3 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                   placeholder="••••••••" />
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Confirm Password</label>
                        <InputText @bind-Value="registerModel.ConfirmPassword" type="password"
                                   class="w-full px-3 py-2.5 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm transition"
                                   placeholder="••••••••" />
                    </div>

                    <button type="submit" disabled="@loading"
                            class="w-full py-2.5 bg-indigo-600 text-white rounded-xl font-semibold hover:bg-indigo-700 transition disabled:opacity-50">
                        @(loading ? "Creating account..." : "Create Account")
                    </button>
                </EditForm>

                <p class="text-center text-sm text-gray-500 mt-5">
                    Already have an account?
                    <button @onclick="() => showRegister = false" class="text-indigo-600 hover:text-indigo-700 font-semibold">Sign In</button>
                </p>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mt-4 p-3 bg-red-50 border border-red-100 rounded-xl text-sm text-red-600 flex items-center gap-2">
                    <span class="material-icons-outlined text-base flex-shrink-0">error_outline</span>
                    @errorMessage
                </div>
            }
        </div>

        @* ── Demo pills ── *@
        <div class="w-full max-w-md">
            <p class="text-xs font-semibold text-indigo-300/50 uppercase tracking-widest mb-3 text-center">Quick Demo Access</p>
            <div class="flex gap-3">
                @foreach (var pill in demoPills)
                {
                    <button @onclick="() => QuickLogin(pill)"
                            class="flex-1 flex flex-col items-center gap-2 px-3 py-3 rounded-xl border border-white/10 bg-white/5 hover:bg-indigo-600/20 hover:border-indigo-500/40 transition-all group">
                        <div class="@PillAvatarClass(pill) w-9 h-9 rounded-full flex items-center justify-center text-white text-xs font-bold">
                            @pill.Initials
                        </div>
                        <div class="text-center">
                            <div class="text-xs font-semibold text-white leading-tight">@pill.Label</div>
                            <div class="text-[10px] text-gray-500 font-mono mt-0.5">@pill.Email</div>
                        </div>
                    </button>
                }
            </div>
        </div>

        <p class="text-xs text-white/20">&copy; 2026 @Branding.CompanyName. All rights reserved.</p>
    </div>
</div>

@code {
    private LoginRequest    loginModel    = new();
    private RegisterRequest registerModel = new();
    private bool loading;
    private bool showRegister;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
        => await Branding.InitAsync();

    private record DemoPill(string Label, string Email, string Password, string Initials, string Role);

    private readonly DemoPill[] demoPills =
    [
        new("Super Admin", "admin@root.com", "admin",  "SA", "Super Admin"),
        new("HR Manager",  "hr@root.com",    "hr1234", "HR", "HR Manager"),
        new("Employee",    "emp@root.com",   "emp123", "JE", "Employee"),
    ];

    private static string PillAvatarClass(DemoPill pill) => pill.Role switch
    {
        "Super Admin" => "bg-indigo-500",
        "HR Manager"  => "bg-green-500",
        _             => "bg-amber-500"
    };

    private async Task QuickLogin(DemoPill pill)
    {
        loading = true; errorMessage = null;
        loginModel = new LoginRequest { Email = pill.Email, Password = pill.Password };
        var result = await Auth.LoginAsync(loginModel);
        if (result.IsSuccess) Nav.NavigateTo("/", true);
        else { errorMessage = result.Message; loading = false; }
    }

    private async Task HandleLogin()
    {
        loading = true; errorMessage = null;
        var result = await Auth.LoginAsync(loginModel);
        if (result.IsSuccess) Nav.NavigateTo("/", true);
        else { errorMessage = result.Message; loading = false; }
    }

    private async Task HandleRegister()
    {
        loading = true; errorMessage = null;
        var result = await Auth.RegisterAsync(registerModel);
        if (result.IsSuccess) Nav.NavigateTo("/", true);
        else { errorMessage = result.Message; loading = false; }
    }
}
