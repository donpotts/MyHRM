@inject AuthService Auth

<PageHeader Title="Active Sessions" Subtitle="Manage your login sessions." />

<div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
    <div class="flex items-center gap-3">
        <span class="material-icons-outlined text-green-500 text-2xl">computer</span>
        <div>
            <p class="text-sm font-medium text-gray-800">Current Session</p>
            <p class="text-xs text-gray-500">Active now &bull; This browser</p>
        </div>
        <span class="ml-auto px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs font-medium">Active</span>
    </div>
</div>

<div class="mt-4">
    <button @onclick="Logout" class="px-4 py-2 bg-red-50 text-red-600 rounded-lg text-sm font-medium hover:bg-red-100">
        Sign Out All Sessions
    </button>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/account/login", true);
    }
}
