@inject ApiService Api

<PageHeader Title="Change Password" Subtitle="Update your account password." />

<EditForm Model="model" OnValidSubmit="Submit" FormName="changePassword">
    <DataAnnotationsValidator />
    <div class="max-w-md space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
            <InputText @bind-Value="model.CurrentPassword" type="password" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm" />
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
            <InputText @bind-Value="model.NewPassword" type="password" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm" />
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
            <InputText @bind-Value="model.ConfirmPassword" type="password" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm" />
        </div>
        <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700">
            Update Password
        </button>
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="p-3 rounded-lg text-sm @(isError ? "bg-red-50 text-red-600" : "bg-green-50 text-green-600")">@message</div>
        }
    </div>
</EditForm>

@code {
    private ChangePasswordRequest model = new();
    private string? message;
    private bool isError;

    private async Task Submit()
    {
        var result = await Api.PostAsync<ChangePasswordRequest, ApiResponse<string>>("/api/profile/change-password", model);
        message = result?.IsSuccess == true ? "Password changed successfully!" : result?.Message ?? "Failed";
        isError = result?.IsSuccess != true;
        if (result?.IsSuccess == true) model = new();
    }
}
