@page "/payroll"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiService Api

<PageTitle>Payroll</PageTitle>

<TabContainer Tabs="tabs" ActiveTab="@activeTab" OnTabChanged="t => { activeTab = t; }" />

<div class="bg-white rounded-b-lg border border-t-0 border-gray-200">
    @switch (activeTab)
    {
        case "Payroll Process":
            <div class="p-4">
                <div class="flex items-center gap-2 mb-2">
                    <button @onclick='() => Nav.NavigateTo("/payroll")' class="text-gray-400 hover:text-gray-600">
                        <span class="material-icons-outlined">arrow_back</span>
                    </button>
                    <div>
                        <h2 class="text-xl font-semibold text-gray-800">Employee Payroll List</h2>
                        <p class="text-sm text-gray-500">Reviewing distribution for period: <strong>@(new DateTime(year, month, 1).ToString("MMMM yyyy"))</strong></p>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4 mt-4">
                    <div class="flex items-center gap-2">
                        <input @bind="search" @bind:event="oninput" placeholder="Search..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full sm:w-48" />
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button class="px-3 py-2 border border-green-500 text-green-600 rounded-lg text-sm font-medium hover:bg-green-50 flex items-center gap-1">
                            <span class="material-icons-outlined text-sm">description</span> Export Excel
                        </button>
                        <button @onclick="LoadPayroll" class="px-3 py-2 border border-gray-300 rounded-lg text-sm flex items-center gap-1 hover:bg-gray-50">
                            <span class="material-icons-outlined text-sm">refresh</span> Refresh
                        </button>
                        @if (selectedId > 0)
                        {
                            <button @onclick="ViewSlip" class="px-3 py-2 border border-blue-500 text-blue-600 rounded-lg text-sm flex items-center gap-1 hover:bg-blue-50">
                                <span class="material-icons-outlined text-sm">receipt</span> Detail
                            </button>
                        }
                    </div>
                </div>

                <div class="overflow-x-auto">
                <table class="w-full min-w-[600px]">
                    <thead>
                        <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                            <th class="px-4 py-3 w-8"></th>
                            <th class="px-4 py-3">NIK</th>
                            <th class="px-4 py-3">Employee</th>
                            <th class="px-4 py-3">Basic Salary</th>
                            <th class="px-4 py-3">Incomes</th>
                            <th class="px-4 py-3">Deductions</th>
                            <th class="px-4 py-3">Take Home Pay</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (payrolls?.Items is not null)
                        {
                            @foreach (var p in payrolls.Items)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50 cursor-pointer @(selectedId == p.Id ? "bg-indigo-50" : "")"
                                    @onclick="() => selectedId = p.Id">
                                    <td class="px-4 py-3">
                                        <input type="checkbox" checked="@(selectedId == p.Id)" class="rounded border-gray-300" @onclick:stopPropagation="true" @onchange="() => selectedId = selectedId == p.Id ? 0 : p.Id" />
                                    </td>
                                    <td class="px-4 py-3 text-sm font-mono">@p.Employee?.EmployeeCode</td>
                                    <td class="px-4 py-3 text-sm">@p.Employee?.FullName</td>
                                    <td class="px-4 py-3 text-sm">@p.BasicSalary.ToString("N0")</td>
                                    <td class="px-4 py-3 text-sm text-green-600">@p.TotalIncome.ToString("N0")</td>
                                    <td class="px-4 py-3 text-sm text-red-600">(@p.TotalDeduction.ToString("N0"))</td>
                                    <td class="px-4 py-3 text-sm font-bold text-green-700">@p.TakeHomePay.ToString("N0")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                </div>
                @if (payrolls is not null)
                {
                    <Pagination Page="page" PageSize="pageSize" TotalCount="payrolls.TotalCount"
                                PageChanged="p => { page = p; _ = LoadPayroll(); }" PageSizeChanged="s => { pageSize = s; page = 1; _ = LoadPayroll(); }" />
                }
            </div>
            break;

        case "Salary Grades":
            <div class="p-4 sm:p-6">
                <PageHeader Title="Salary Grades" Subtitle="Configure salary grade structures." />
                @if (grades is not null)
                {
                    <div class="overflow-x-auto">
                    <table class="w-full min-w-[400px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Grade</th>
                                <th class="px-4 py-3">Description</th>
                                <th class="px-4 py-3">Basic Salary</th>
                                <th class="px-4 py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in grades)
                            {
                                <tr class="border-b border-gray-50 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-sm font-medium">@g.Name</td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@g.Description</td>
                                    <td class="px-4 py-3 text-sm font-medium">@g.BasicSalary.ToString("N0")</td>
                                    <td class="px-4 py-3"><span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Active</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
            </div>
            break;

        case "Income Components":
            <div class="p-4 sm:p-6">
                <PageHeader Title="Income Components" Subtitle="Manage allowances and additional income types." />
                @if (incomeComponents is not null)
                {
                    <div class="overflow-x-auto">
                    <table class="w-full min-w-[350px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Name</th><th class="px-4 py-3">Description</th><th class="px-4 py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in incomeComponents)
                            {
                                <tr class="border-b border-gray-50"><td class="px-4 py-3 text-sm font-medium">@c.Name</td><td class="px-4 py-3 text-sm text-gray-500">@c.Description</td><td class="px-4 py-3"><span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Active</span></td></tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
            </div>
            break;

        case "Deductions":
            <div class="p-4 sm:p-6">
                <PageHeader Title="Deduction Components" Subtitle="Manage deduction types and policies." />
                @if (deductionComponents is not null)
                {
                    <div class="overflow-x-auto">
                    <table class="w-full min-w-[350px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3">Name</th><th class="px-4 py-3">Description</th><th class="px-4 py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in deductionComponents)
                            {
                                <tr class="border-b border-gray-50"><td class="px-4 py-3 text-sm font-medium">@c.Name</td><td class="px-4 py-3 text-sm text-gray-500">@c.Description</td><td class="px-4 py-3"><span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">Active</span></td></tr>
                            }
                        </tbody>
                    </table>
                    </div>
                }
            </div>
            break;
    }
</div>

@* Payroll Slip Modal *@
<Modal IsVisible="showSlip" Title="PAYROLL SLIP DETAILS" OnClose="() => showSlip = false" WidthClass="w-[650px]">
    <ChildContent>
        @if (slip is not null)
        {
            <div class="border border-gray-200 rounded-lg overflow-hidden">
                <div class="flex justify-between p-4 bg-gray-50">
                    <div>
                        <p class="text-xs text-gray-500">Employee Name</p>
                        <p class="font-bold text-indigo-600">@slip.EmployeeName</p>
                        <p class="text-xs text-gray-500 mt-2">Code</p>
                        <p class="font-medium">@slip.EmployeeCode</p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs text-gray-500">Payroll Period</p>
                        <p class="font-bold">@slip.Period</p>
                        <p class="text-xs text-gray-500 mt-2">Basic Salary</p>
                        <p class="font-bold">@slip.BasicSalary.ToString("N0")</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-0">
                    <div class="p-4 border-r border-gray-200">
                        <h4 class="text-sm font-bold text-green-600 mb-2">Incomes (+)</h4>
                        @foreach (var inc in slip.Incomes)
                        {
                            <div class="flex justify-between text-sm py-1"><span>@inc.Name</span><span>@inc.Amount.ToString("N0")</span></div>
                        }
                    </div>
                    <div class="p-4">
                        <h4 class="text-sm font-bold text-red-600 mb-2">Deductions (-)</h4>
                        @foreach (var ded in slip.Deductions)
                        {
                            <div class="flex justify-between text-sm py-1"><span>@ded.Name</span><span class="text-red-600">(@ded.Amount.ToString("N0"))</span></div>
                        }
                    </div>
                </div>

                <div class="flex justify-between items-center p-4 bg-blue-600 text-white">
                    <span class="font-bold text-lg">TAKE HOME PAY</span>
                    <span class="font-bold text-2xl">@slip.TakeHomePay.ToString("N0")</span>
                </div>
            </div>
        }
    </ChildContent>
    <Footer>
        <button @onclick="() => showSlip = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Close</button>
        <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-700 flex items-center gap-1">
            <span class="material-icons-outlined text-sm">print</span> Print PDF Slip
        </button>
    </Footer>
</Modal>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string activeTab = "Payroll Process";
    private Dictionary<string, string> tabs = new()
    {
        ["Payroll Process"] = "payments",
        ["Salary Grades"] = "workspace_premium",
        ["Income Components"] = "add_circle",
        ["Deductions"] = "remove_circle"
    };

    private PagedResult<EmployeePayroll>? payrolls;
    private List<SalaryGrade>? grades;
    private List<IncomeComponent>? incomeComponents;
    private List<DeductionComponent>? deductionComponents;
    private PayrollSlipDto? slip;
    private string search = "";
    private int page = 1, pageSize = 5;
    private int month = 3, year = 2026;
    private int selectedId;
    private bool showSlip;

    protected override async Task OnInitializedAsync()
    {
        await LoadPayroll();
        grades = (await Api.GetAsync<ApiResponse<List<SalaryGrade>>>("/api/salary-grades"))?.Data;
        incomeComponents = (await Api.GetAsync<ApiResponse<List<IncomeComponent>>>("/api/income-components"))?.Data;
        deductionComponents = (await Api.GetAsync<ApiResponse<List<DeductionComponent>>>("/api/deduction-components"))?.Data;
    }

    private async Task LoadPayroll()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<EmployeePayroll>>>($"/api/payroll?page={page}&pageSize={pageSize}&search={search}&month={month}&year={year}");
        payrolls = r?.Data;
    }

    private async Task ViewSlip()
    {
        if (selectedId <= 0) return;
        var r = await Api.GetAsync<ApiResponse<PayrollSlipDto>>($"/api/payroll/{selectedId}/slip");
        slip = r?.Data;
        showSlip = true;
    }
}
