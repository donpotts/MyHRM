@page "/performance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiService Api

<PageTitle>Performance</PageTitle>

<TabContainer Tabs="tabs" ActiveTab="@activeTab" OnTabChanged="t => { activeTab = t; }" />

<div class="bg-white rounded-b-lg border border-t-0 border-gray-200">
    @switch (activeTab)
    {
        case "Evaluation":
            <div class="p-4">
                <PageHeader Title="Performance Evaluation" Subtitle="Review and manage employee performance ratings and periodic assessments.">
                    <Breadcrumb><span>/ Performance / <strong>Evaluation</strong></span></Breadcrumb>
                </PageHeader>

                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                    <div class="flex items-center gap-2">
                        <input @bind="search" @bind:event="oninput" placeholder="Search..." class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-full sm:w-48" />
                        <button @onclick="LoadEvals" class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium whitespace-nowrap">Search</button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button class="px-3 py-2 border border-green-500 text-green-600 rounded-lg text-sm font-medium hover:bg-green-50 flex items-center gap-1">
                            <span class="material-icons-outlined text-sm">description</span>
                            <span class="hidden sm:inline">Export Excel</span>
                        </button>
                        <button @onclick="LoadEvals" class="px-3 py-2 border border-gray-300 rounded-lg text-sm flex items-center gap-1 hover:bg-gray-50">
                            <span class="material-icons-outlined text-sm">refresh</span>
                            <span class="hidden sm:inline">Refresh</span>
                        </button>
                        @if (selectedEval is not null)
                        {
                            <button @onclick="() => showDetail = true" class="px-3 py-2 border border-blue-500 text-blue-600 rounded-lg text-sm flex items-center gap-1 hover:bg-blue-50">
                                <span class="material-icons-outlined text-sm">visibility</span>
                                <span class="hidden sm:inline">View Detail</span>
                            </button>
                            <button class="px-3 py-2 border border-yellow-500 text-yellow-600 rounded-lg text-sm flex items-center gap-1 hover:bg-yellow-50">
                                <span class="material-icons-outlined text-sm">edit</span>
                                <span class="hidden sm:inline">Edit</span>
                            </button>
                            <button @onclick="DeleteEval" class="px-3 py-2 bg-red-600 text-white rounded-lg text-sm flex items-center gap-1 hover:bg-red-700">
                                <span class="material-icons-outlined text-sm">delete</span>
                                <span class="hidden sm:inline">Remove</span>
                            </button>
                        }
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full min-w-[600px]">
                        <thead>
                            <tr class="text-left text-xs text-gray-500 uppercase border-b border-gray-200">
                                <th class="px-4 py-3 w-8"></th>
                                <th class="px-4 py-3">Employee</th>
                                <th class="px-4 py-3">Period</th>
                                <th class="px-4 py-3">Final Score</th>
                                <th class="px-4 py-3">Rating</th>
                                <th class="px-4 py-3">Evaluator</th>
                                <th class="px-4 py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (evals?.Items is not null)
                            {
                                @foreach (var ev in evals.Items)
                                {
                                    <tr class="border-b border-gray-50 hover:bg-gray-50 cursor-pointer @(selectedEval?.Id == ev.Id ? "bg-indigo-50" : "")"
                                        @onclick="() => selectedEval = ev">
                                        <td class="px-4 py-3">
                                            <input type="checkbox" checked="@(selectedEval?.Id == ev.Id)" class="rounded border-gray-300" @onclick:stopPropagation="true" @onchange="() => selectedEval = selectedEval?.Id == ev.Id ? null : ev" />
                                        </td>
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-2">
                                                <div class="w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0" style="background-color: @AvatarColor(ev.Employee?.FirstName ?? "")">
                                                    @Initials(ev.Employee?.FirstName, ev.Employee?.LastName)
                                                </div>
                                                <div>
                                                    <div class="text-sm font-medium">@ev.Employee?.FullName</div>
                                                    <div class="text-xs text-gray-400">@ev.Employee?.EmployeeCode</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 text-sm">@ev.Period</td>
                                        <td class="px-4 py-3 text-sm font-medium text-green-600">@ev.FinalScore.ToString("F1") / 100</td>
                                        <td class="px-4 py-3">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="text-sm @(i <= ev.Rating ? "star-filled" : "star-empty")">&#9733;</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-sm">@ev.Evaluator</td>
                                        <td class="px-4 py-3">
                                            <span class="px-2 py-0.5 rounded text-xs font-medium @(ev.Status == EvaluationStatus.Completed ? "bg-green-100 text-green-700" : "bg-yellow-100 text-yellow-700")">
                                                @ev.Status.ToString().ToUpper()
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                @if (evals is not null)
                {
                    <Pagination Page="page" PageSize="pageSize" TotalCount="evals.TotalCount"
                                PageChanged="async p => { page = p; await LoadEvals(); }" PageSizeChanged="async s => { pageSize = s; page = 1; await LoadEvals(); }" />
                }
            </div>
            break;

        case "Appraisal":
            <div class="p-4 sm:p-6"><PageHeader Title="Appraisal" Subtitle="Employee appraisal records." /> <p class="text-gray-400 text-sm">Appraisal data will be displayed here.</p></div>
            break;
        case "Promotion":
            <div class="p-4 sm:p-6"><PageHeader Title="Promotions" Subtitle="Track employee promotions." /> <p class="text-gray-400 text-sm">Promotion records will be displayed here.</p></div>
            break;
        case "Transfer":
            <div class="p-4 sm:p-6"><PageHeader Title="Transfers" Subtitle="Employee transfer management." /> <p class="text-gray-400 text-sm">Transfer records will be displayed here.</p></div>
            break;
    }
</div>

<Modal IsVisible="showDetail" Title="Evaluation Detail" OnClose="() => showDetail = false">
    <ChildContent>
        @if (selectedEval is not null)
        {
            <div class="space-y-3">
                <div class="flex justify-between"><span class="text-gray-500">Employee</span><span class="font-medium">@selectedEval.Employee?.FullName</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Period</span><span>@selectedEval.Period</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Score</span><span class="text-green-600 font-bold">@selectedEval.FinalScore / 100</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Rating</span><span>@selectedEval.Rating / 5</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Evaluator</span><span>@selectedEval.Evaluator</span></div>
                <div class="flex justify-between"><span class="text-gray-500">Status</span><span>@selectedEval.Status</span></div>
            </div>
        }
    </ChildContent>
    <Footer>
        <button @onclick="() => showDetail = false" class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Close</button>
    </Footer>
</Modal>

@code {
    private string activeTab = "Evaluation";
    private Dictionary<string, string> tabs = new()
    {
        ["Evaluation"] = "assignment",
        ["Appraisal"] = "grading",
        ["Promotion"] = "trending_up",
        ["Transfer"] = "swap_horiz"
    };

    private PagedResult<Evaluation>? evals;
    private Evaluation? selectedEval;
    private string search = "";
    private int page = 1, pageSize = 5;
    private bool showDetail;

    protected override async Task OnInitializedAsync() => await LoadEvals();

    private async Task LoadEvals()
    {
        var r = await Api.GetAsync<ApiResponse<PagedResult<Evaluation>>>($"/api/evaluations?page={page}&pageSize={pageSize}&search={search}");
        evals = r?.Data;
    }

    private async Task DeleteEval()
    {
        if (selectedEval is null) return;
        await Api.DeleteAsync($"/api/evaluations/{selectedEval.Id}");
        selectedEval = null;
        await LoadEvals();
    }

    private string Initials(string? first, string? last) => $"{first?.FirstOrDefault()}{last?.FirstOrDefault()}";
    private string AvatarColor(string name)
    {
        var colors = new[] { "#22c55e", "#3b82f6", "#f59e0b", "#ef4444", "#8b5cf6", "#06b6d4" };
        return colors[Math.Abs(name.GetHashCode()) % colors.Length];
    }
}
